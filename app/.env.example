# moduleCad — production secrets for Coolify deployment.
#
# Copy these into the Coolify per-resource environment editor (raw .env view
# works). Generate strong values with `openssl rand -base64 <n>`.
#
# These are the compose-level ${VAR} substitutions consumed by
# docker-compose.yml. Per-app dev examples live in apps/*/.env.example.

# Postgres superuser password for the modulecad database.
POSTGRES_PASSWORD=__GENERATE__

# RustFS root credentials (S3 access key / secret). The web app and the
# dwg-converter both use these.
RUSTFS_ACCESS_KEY=modulecad
RUSTFS_SECRET_KEY=__GENERATE__

# better-auth session signing secret.
BETTER_AUTH_SECRET=__GENERATE__

# Shared secret between the web app and the dwg-converter (the converter
# uses this in the x-dwg-converter-secret header when calling
# /api/jobs/:id/update).
DWG_CONVERTER_SECRET=__GENERATE__

# ── FQDNs (set these in the Coolify service Domains UI instead; shown for
# reference). Coolify injects SERVICE_FQDN_WEB and SERVICE_FQDN_RUSTFS.
# SERVICE_FQDN_WEB=https://cad.example.com
# SERVICE_FQDN_RUSTFS=https://cdn.example.com
