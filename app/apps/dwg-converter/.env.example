# dwg-converter — local development environment.
# Copy to .env. In Coolify these come from the per-resource env editor.

PORT=8080

# Shared secret with the web app (POST /api/jobs/:id/update uses this header).
DWG_CONVERTER_SECRET=dev-converter-secret

# RustFS — same store as the web app, internal endpoint.
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_ACCESS_KEY=modulecad
RUSTFS_SECRET_KEY=modulecad-dev-key

# dwg2dxf and dxf2dwg must be on PATH. Install LibreDWG:
#   brew install libredwg        (macOS)
#   apt install libredwg-tools   (Debian/Ubuntu)
# Verify: which dwg2dxf && which dxf2dwg
