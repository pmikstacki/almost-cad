# moduleCad web app — local development environment.
# Copy to .env and fill in. In Coolify these are set per-resource in the UI.

# Postgres (matches docker-compose.yml defaults; override if you run your own)
DATABASE_URL=postgres://modulecad:modulecad@localhost:5432/modulecad

# better-auth session secret. Generate one for any non-local environment:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=dev-only-insecure-secret-change-me

# RustFS (S3-compatible) — internal endpoint used by the server, and the
# browser-facing public endpoint used for presigned upload URLs.
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_PUBLIC_ENDPOINT=http://localhost:9000
RUSTFS_ACCESS_KEY=modulecad
RUSTFS_SECRET_KEY=modulecad-dev-key
RUSTFS_BUCKET=modulecad

# dwg-converter microservice (internal)
DWG_CONVERTER_URL=http://localhost:8080
