{
  "name": "@mlightcad/cad-viewer-example",
  "private": true,
  "version": "1.5.5",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/mlightcad/cad-viewer.git"
  },
  "scripts": {
    "analyze": "vite build --mode analyze",
    "build": "vue-tsc && vite build",
    "clean": "rimraf dist lib tsconfig.tsbuildinfo",
    "dev": "vite",
    "dev:local-data-model": "vite --mode local-data-model",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix --quiet src/",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@vitejs/plugin-vue": "^5.1.3",
    "vite": "^5.4.19",
    "vite-plugin-static-copy": "^3.1.1",
    "vite-svg-loader": "^5.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.1.6"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@mlightcad/cad-html-plugin": "workspace:*",
    "@mlightcad/cad-pdf-plugin": "workspace:*",
    "@mlightcad/cad-simple-viewer": "workspace:*",
    "@mlightcad/cad-viewer": "workspace:*",
    "@mlightcad/data-model": "^1.9.5",
    "element-plus": "^2.12.0",
    "lodash-es": "4.17.21",
    "three": "^0.172.0",
    "vue": "^3.4.21",
    "vue-i18n": "^11.4.4"
  }
