{
  "name": "@mlightcad/cad-html-plugin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/cad-html-plugin/src",
  "projectType": "library",
  "tags": [
    "npm:private"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc && vite build && vite build --config vite.viewer.config.ts",
        "cwd": "packages/cad-html-plugin"
      },
      "dependsOn": [
        "^build"
      ],
      "cache": true
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rimraf dist lib tsconfig.tsbuildinfo",
        "cwd": "packages/cad-html-plugin"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint src/",
        "cwd": "packages/cad-html-plugin"
      }
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint --fix --quiet src/",
        "cwd": "packages/cad-html-plugin"
      }
    }
  }
}
