{
  "name": "@mlightcad/cad-html-plugin",
  "version": "1.5.5",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/mlightcad/cad-viewer.git"
  },
  "files": [
    "dist",
    "lib",
    "README.md",
    "package.json"
  ],
  "main": "./dist/cad-html-plugin.umd.cjs",
  "module": "./dist/cad-html-plugin.js",
  "types": "./lib/index.d.ts",
  "typesVersions": {
    "*": {
      "register": [
        "lib/register.d.ts"
      ]
    }
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./dist/cad-html-plugin.js",
      "require": "./dist/cad-html-plugin.umd.cjs"
    },
    "./register": {
      "types": "./lib/register.d.ts",
      "import": "./dist/cad-html-plugin-register.js",
      "require": "./dist/cad-html-plugin-register.umd.cjs"
    },
    "./viewer-runtime": {
      "import": "./dist/viewer-runtime.iife.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist lib tsconfig.tsbuildinfo",
    "build": "tsc && vite build && vite build --config vite.viewer.config.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix --quiet src/"
  },
  "devDependencies": {
    "@mlightcad/cad-simple-viewer": "workspace:*",
    "@mlightcad/data-model": "^1.9.5",
    "@mlightcad/three-renderer": "workspace:*",
    "@types/jest": "^29.5.12",
    "@types/rbush": "^3.0.4",
    "@types/three": "^0.172.0",
    "fflate": "^0.8.2",
    "rbush": "^4.0.1",
    "three": "^0.172.0"
  },
  "peerDependencies": {
    "@mlightcad/cad-simple-viewer": "workspace:*",
    "@mlightcad/data-model": "^1.9.5",
    "@mlightcad/three-renderer": "workspace:*",
    "three": "^0.172.0"
  }
}
