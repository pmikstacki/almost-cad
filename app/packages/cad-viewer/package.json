{
  "name": "@mlightcad/cad-viewer",
  "version": "1.5.5",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/mlightcad/cad-viewer.git"
  },
  "keywords": [
    "autocad",
    "cad",
