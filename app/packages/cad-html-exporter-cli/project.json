{
  "name": "@mlightcad/cad-html-exporter-cli",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/cad-html-exporter-cli/src",
  "projectType": "application",
  "tags": [
    "npm:private"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc && vite build --config vite.runner.config.ts && node scripts/copy-runner-assets.mjs",
        "cwd": "packages/cad-html-exporter-cli"
      },
      "dependsOn": [
        "^build",
        {
          "projects": [
            "@mlightcad/cad-html-plugin"
          ],
          "target": "build"
        }
      ],
      "cache": true
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rimraf dist dist-runner tsconfig.tsbuildinfo",
        "cwd": "packages/cad-html-exporter-cli"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint src/",
        "cwd": "packages/cad-html-exporter-cli"
      }
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint --fix --quiet src/",
        "cwd": "packages/cad-html-exporter-cli"
      }
    }
  }
}
